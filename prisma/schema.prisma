// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER, DOCTOR, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  doctorProfile Doctor?
  patientProfile Patient?
}

model Doctor {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization     String
  experienceYears    Int
  consultationFee    Float
  location           String
  city               String   @default("Sonipat") // Core focus city
  clinicImages       String?  // JSON string array of URLs
  verificationLevel  String   @default("BASIC") // BASIC, FULL_CLINIC_VISIT
  acceptsGovtSchemes Boolean  @default(false)
  status             String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  mciRegNumber       String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appointments       Appointment[]
  treatmentEstimates TreatmentEstimate[]
}

model Patient {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age              Int?
  gender           String?
  bloodGroup       String?
  govtSchemeId     String?  // Ayushman Bharat etc.
  isSchemeVerified Boolean  @default(false)
  preferredLanguage String  @default("en") // 'en' or 'hi'
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointments     Appointment[]
}

model TreatmentEstimate {
  id              String   @id @default(cuid())
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  procedureName   String
  consultationFee Float
  approxTestCost  Float?
  approxMedCost   Float?
  totalEstimate   Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(cuid())
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id])
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  appointmentDate DateTime
  status          String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  paymentStatus   String   @default("PENDING") // PENDING, PAID, REFUNDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  review Review?
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
}
